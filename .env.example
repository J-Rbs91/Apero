# Ce fichier est un modele : le vrai .env ne doit JAMAIS etre commite
# (le .gitignore racine exclut deja .env et .env.*).

# ============================================================
# FRONTEND - GitHub Pages / Vite
# ============================================================
# Toutes les variables prefixees VITE_ sont publiques dans le bundle final.
# Ne jamais placer de secret durable dans une variable VITE_.

# URL de base de l'application frontend.
VITE_APP_BASE_URL=https://j-rbs91.github.io/Apero

# URL de la mini API VPS utilisee par le frontend pour les ecritures.
# En developpement local, pointer vers une API lancee sur la machine de dev
# (l'API ecoute cote VPS sur 127.0.0.1:3103, meme port conseille en local).
VITE_APERO_API_BASE_URL=http://127.0.0.1:3103
# Exemple d'URL publique exposee par Caddy avec prefixe strippe :
# VITE_APERO_API_BASE_URL=https://panum.fr/_svc/a

# Mode de stockage utilise par le frontend.
# legacy-github = ancien systeme en lecture publique uniquement, sans token frontend
# api-vps       = nouveau systeme chiffre via la mini API VPS
# Absente ou inconnue => api-vps.
VITE_APERO_STORAGE_MODE=api-vps

# Configuration GitHub actuellement lue par le frontend.
# Ces valeurs ne sont pas secretes, mais restent compilees dans le bundle Vite.
VITE_GITHUB_OWNER=J-Rbs91
VITE_GITHUB_REPO=Apero
VITE_GITHUB_BRANCH=main

# ============================================================
# SERVER - Mini API VPS (server/)
# ============================================================
# Les variables ci-dessous ne doivent jamais etre exposees au frontend.
# Elles doivent etre definies uniquement sur le VPS.
# En local : placer un .env dans server/ (jamais commite).
# Note : l'API ecrit les fichiers aperos chiffres uniquement sous data/aperos/
# (chemin verrouille dans server/src/config.ts, volontairement non configurable).

# Ces variables (GITHUB_TOKEN, HOST, PORT, ...) sont des variables serveur :
# elles ne doivent JAMAIS etre lues ni utilisees dans le code frontend.

# Token GitHub fine-grained utilise par l'API serveur pour ecrire dans le repo.
# GITHUB_TOKEN doit exister uniquement cote serveur, jamais dans le frontend.
GITHUB_TOKEN=replace_with_server_side_github_token

# Adresse d'ecoute locale de l'API sur le VPS (derriere Caddy).
HOST=127.0.0.1

# Proprietaire du repo GitHub.
GITHUB_OWNER=J-Rbs91

# Nom du repo GitHub.
GITHUB_REPO=Apero

# Branche cible pour l'ecriture des fichiers apero.
GITHUB_BRANCH=main

# Origine(s) frontend autorisee(s) pour CORS, separees par des virgules.
# Exemple local : ALLOWED_ORIGIN=https://j-rbs91.github.io,http://localhost:5173
ALLOWED_ORIGIN=https://j-rbs91.github.io

# Port local de l'API Node.js sur le VPS (3001 = PANUM, 3002 = ORTABEL, 3103 = Apero).
PORT=3103

# Limite de taille des payloads JSON recus par l'API.
JSON_BODY_LIMIT=100kb

# Nombre de proxies de confiance devant Express (Caddy/Nginx sur le meme VPS = 1).
TRUST_PROXY_HOPS=1

# Rate limit general sur /api, par IP.
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=60

# Rate limit plus strict sur les ecritures POST /api/aperos/:aperoId, par IP.
WRITE_RATE_LIMIT_WINDOW_MS=60000
WRITE_RATE_LIMIT_MAX=10

# Taille maximale du champ ciphertext, en caracteres base64url.
MAX_CIPHERTEXT_LENGTH=80000

# Timeouts anti-epuisement de ressources.
GITHUB_REQUEST_TIMEOUT_MS=8000
SERVER_REQUEST_TIMEOUT_MS=15000

# Migration uniquement : autoriser temporairement la suppression d'anciens aperos
# crees avant adminKeyHash avec la write key partagee. Garder false par defaut.
ALLOW_LEGACY_WRITE_KEY_DELETE=false

# Optionnel : niveau de logs.
LOG_LEVEL=info
